{
  "default_mpich": {
    "desc": "MPICH default algorithm selection",
    "version": "4.3.0",
    "constraints": [
      {
        "key": "count",
        "conditions": [
          {
            "operator": ">=",
            "value": "comm_sz"
          }
        ]
      }
    ],
    "selection": "auto",
    "tags": [
      "default"
    ]
  },
  "binomial_mpich": {
    "desc": "MPICH binomial tree based algorithm.",
    "version": "4.3.0",
    "constraints": [
      {
        "key": "count",
        "conditions": [
          {
            "operator": ">=",
            "value": "comm_sz"
          }
        ]
      }
    ],
    "selection": "binomial",
    "tags": [
      "binomial"
    ]
  },
  "non_blocking_mpich": {
    "desc": "MPICH non-blocking algorithm.",
    "version": "4.3.0",
    "constraints": [
      {
        "key": "count",
        "conditions": [
          {
            "operator": ">=",
            "value": "comm_sz"
          }
        ]
      }
    ],
    "selection": "nb",
    "tags": [
      "non_blocking"
    ]
  },
  "bine_mpich": {
    "desc": "custom MPICH bine algorithm.",
    "version": "5.0.0b1",
    "constraints": [
      {
        "key": "count",
        "conditions": [
          {
            "operator": ">=",
            "value": "comm_sz"
          }
        ]
      },
      {
        "key": "comm_sz",
        "conditions": [
          {
            "operator": "is_power_of_two",
            "value": true
          }
        ]
      }
    ],
    "selection": "bine",
    "tags": [
      "bine"
    ]
  }
}
