  "rabenseifner_mpich": {
    "desc": "MPICH Rabenseifner algorithm. Internally is called reduce_scatter_gather",
    "version": "4.3.0",
    "constraints": [
      {
        "key": "count",
        "conditions": [
          {
            "operator": ">=",
            "value": "comm_sz"
          }
        ]
      }
    ],
    "selection": "reduce_scatter_gather",
    "tags": [
      "rabenseifner"
    ]
  },
