            ]
          },
          {
            "name": "recursive_halving_ompi",
            "coll": "reduce_scatter",
            "desc": "Open MPI recursive halving algorithm. Similar to `basic`'s reduce scatter. Works only for commutative `op`. This algorithm is used for small to medium messages",
            "version": "4.1.5",
            "selection": 2,
            "constraints": [
              {
                "key": "count",
                "conditions": [
                  {
                    "operator": ">=",
