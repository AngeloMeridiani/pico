{
  "environment": {
    "desc": "Leonardo HPC cluster.",
    "name": "leonardo",
    "slurm": true,
    "python_module": "python/3.11.6--gcc--8.5.0",
    "other_var": {
      "UCX_IB_SL": "1"
    },
    "partition": {
      "environment": "leonardo",
      "desc": "Boost partition with GPU nodes.",
      "name": "boost_usr_prod",
      "is_gpu": true,
      "cpus_per_node": 32,
      "sockets_per_node": 1,
      "gpus_per_node": 4,
      "qos": {
        "partition": "boost_usr_prod",
        "environment": "leonardo",
        "desc": "Default QOS for boost partition.",
        "name": "default",
        "is_required": false,
        "nodes_limit": {
          "min": 2,
          "max": 64
        },
        "time_limit": "24:00:00"
      }
    }
  },
  "test": {
    "compile_only": false,
    "debug_mode": false,
    "dry_run": false,
    "compress": true,
    "delete": true,
    "number_of_nodes": 64,
    "output_level": "minimal",
    "dimensions": {
      "dtype": "int32",
      "sizes_bytes": [
        32,
        256,
        2048,
        16384,
        131072,
        1048576,
        8388608,
        67108864,
        536870912
      ],
      "sizes_elements": [
        8,
        64,
        512,
        4096,
        32768,
        262144,
        2097152,
        16777216,
        134217728
      ],
      "segsizes_bytes": [
        0
      ]
    },
    "test_time": "01:00:00"
  },
  "libraries": [
    {
      "name": "Open MPI Custom",
      "desc": "System custom Open MPI installation with additional algorithms.",
      "tests": {
        "cpu": [
          1
        ]
      },
      "standard": "MPI",
      "lib_type": "Open-MPI",
      "version": "6.1.0",
      "compiler": "mpicc",
      "gpu_support": {
        "gpu": false
      },
      "lib_load": {
        "type": "set_env",
        "env_var": {
          "PATH": "$HOME/bin:$PATH",
          "LD_LIBRARY_PATH": "$HOME/lib:$LD_LIBRARY_PATH",
          "MANPATH": "$HOME/share:$MANPATH"
        }
      },
      "pico_backend": true,
      "algorithms": {
        "gather": [
          {
            "name": "binomial_ompi",
            "coll": "gather",
            "desc": "Open MPI binomial tree based algorithm.",
            "version": "4.1.5",
            "selection": 2,
            "constraints": [
              {
                "key": "count",
                "conditions": [
                  {
                    "operator": ">=",
                    "value": "comm_sz"
                  }
                ]
              }
            ],
            "tags": [
              "binomial"
            ]
          },
          {
            "name": "bine_ompi",
            "coll": "gather",
            "desc": "Open MPI bine tree algorithm (experimental)",
            "version": "6.1.0",
            "selection": 4,
            "constraints": [
              {
                "key": "comm_sz",
                "conditions": [
                  {
                    "operator": "is_power_of_two",
                    "value": true
                  }
                ]
              }
            ],
            "tags": [
              "bine"
            ]
          },
          {
            "name": "bine_over",
            "coll": "gather",
            "desc": "libpico external bine algorithm. It uses a binomial tree pattern of communication choosing its peer utilizing `bine` peer selection method `pi`. It works only if `comm` is a power of 2 and root is 0.",
            "version": "1.0.0",
            "selection": "pico",
            "constraints": [
              {
                "key": "count",
                "conditions": [
                  {
                    "operator": ">=",
                    "value": "comm_sz"
                  }
                ]
              },
              {
                "key": "comm_sz",
                "conditions": [
                  {
                    "operator": "is_power_of_two",
                    "value": true
                  }
                ]
              },
              {
                "key": "root",
                "conditions": [
                  {
                    "operator": "==",
                    "value": 0
                  }
                ]
              }
            ],
            "tags": [
              "bine",
              "external"
            ]
          }
        ],
        "scatter": [
          {
            "name": "binomial_ompi",
            "coll": "scatter",
            "desc": "Open MPI binomial tree based algorithm.",
            "version": "4.1.5",
            "selection": 2,
            "constraints": [
              {
                "key": "count",
                "conditions": [
                  {
                    "operator": ">=",
                    "value": "comm_sz"
                  }
                ]
              }
            ],
            "tags": [
              "binomial"
            ]
          },
          {
            "name": "bine_ompi",
            "coll": "scatter",
            "desc": "Open MPI bine.",
            "version": "6.1.0",
            "selection": 4,
            "constraints": [
              {
                "key": "comm_sz",
                "conditions": [
                  {
                    "operator": "is_power_of_two",
                    "value": true
                  }
                ]
              }
            ],
            "tags": [
              "bine"
            ]
          },
          {
            "name": "bine_over",
            "coll": "scatter",
            "desc": "libpico external bine algorithm.",
            "version": "1.0.0",
            "selection": "pico",
            "constraints": [
              {
                "key": "count",
                "conditions": [
                  {
                    "operator": ">=",
                    "value": "comm_sz"
                  }
                ]
              },
              {
                "key": "comm_sz",
                "conditions": [
                  {
                    "operator": "is_power_of_two",
                    "value": true
                  }
                ]
              },
              {
                "key": "root",
                "conditions": [
                  {
                    "operator": "==",
                    "value": 0
                  }
                ]
              }
            ],
            "tags": [
              "bine",
              "external"
            ]
          }
        ]
      }
    },
